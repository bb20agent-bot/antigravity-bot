;; Get methods of a Contract VoraTreasury
;;

_ %owner() method_id(83229) {
    var self = $VoraTreasury$_contract_load();
    var res = self~$VoraTreasury$_fun_owner();
    return res;
}

;;
;; Routing of a Contract VoraTreasury
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address) = $VoraTreasury$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    int op = 0;
    int in_msg_length = slice_bits(in_msg);
    if (in_msg_length >= 32) {
        op = in_msg~load_uint(32);
        ;; Receive WithdrawIDO message
        if (op == 800788723) {
            var $msg'strategy_amount = in_msg~load_varuint16();
            var $msg'dev_amount = in_msg~load_varuint16();
            var $msg'dex_amount = in_msg~load_varuint16();
            ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_requireOwner();
            int $total = (($msg'strategy_amount + $msg'dev_amount) + $msg'dex_amount);
            if (($msg'strategy_amount > 0)) {
                ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_send_jettons($self'strategy_address, $msg'strategy_amount, __gen_slice_string_0da95c8bdb4088b274841eb642ea2084da9e28c653cbc8bd50cd8fe03b34e431());
            }
            if (($msg'dev_amount > 0)) {
                ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_send_jettons($self'dev_address, $msg'dev_amount, __gen_slice_string_1645018f16e52d38dc32d614ec2644d0e93487525b502d146175369898d724c6());
            }
            if (($msg'dex_amount > 0)) {
                ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_send_jettons($self'dex_address, $msg'dex_amount, __gen_slice_string_79e0183dee85eccd9621048003bf38e8d5955e31e9e2f39e2c9cedb636383235());
            }
            $VoraTreasury$_contract_store(($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address));
            return ();
        }
        
        ;; Receive WithdrawSubscription message
        if (op == 833932536) {
            var $msg'strategy_amount = in_msg~load_varuint16();
            var $msg'tech_amount = in_msg~load_varuint16();
            var $msg'dex_lp_amount = in_msg~load_varuint16();
            var $msg'p2p_brokerage_amount = in_msg~load_varuint16();
            ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_requireOwner();
            if (($msg'strategy_amount > 0)) {
                ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_send_jettons($self'strategy_address, $msg'strategy_amount, __gen_slice_string_79368612f8a140a6646fa122b2fa3dbaba55dfd26aa56d84b9e6911e88b49c9f());
            }
            if (($msg'tech_amount > 0)) {
                ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_send_jettons($self'tech_incentive_address, $msg'tech_amount, __gen_slice_string_1bb2451b5196a3e49e0faa77bceafc691426edf7d2752b351982cf3d3dd6e120());
            }
            if (($msg'dex_lp_amount > 0)) {
                ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_send_jettons($self'dex_address, $msg'dex_lp_amount, __gen_slice_string_cecd3326153cadb7a4711300a3c422144feb0eb44b47ff51594093081642a63d());
            }
            if (($msg'p2p_brokerage_amount > 0)) {
                ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_send_jettons($self'p2p_brokerage_address, $msg'p2p_brokerage_amount, __gen_slice_string_c357d91fff279bdb8f9cf203ba06dcb4e23282270b6b8afa7cbd8b5901b802c3());
            }
            $VoraTreasury$_contract_store(($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address));
            return ();
        }
        
        ;; Receive Deploy message
        if (op == 0x946a98b6) {
            var $deploy'queryId = in_msg~load_uint(64);
            ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
            $VoraTreasury$_contract_store(($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address));
            return ();
        }
        
    }
    ;; Empty Receiver and Text Receivers
    var text_op = slice_hash(in_msg);
    ;; Receive "Set Jetton Wallet" message
    if (text_op == 0x71a1ec67b1d252cdd4096d9115e629e01397e30cc2422b00d08f3b5aba8eb347) {
        var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
        $self'vora_jetton_wallet = __tact_context_get_sender();
        $VoraTreasury$_contract_store(($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address));
        return ();
    }
    ;; Receive "withdraw_ton" message
    if (text_op == 0x43f2b4a3430a592bb785c71e3e454e8011ac68a50641c9f853dc559f547c9862) {
        ($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address)~$VoraTreasury$_fun_requireOwner();
        $global_send($SendParameters$_constructor_to_value_mode($self'owner, 0, 130));
        $VoraTreasury$_contract_store(($self'owner, $self'vora_jetton_wallet, $self'total_ido_revenue, $self'total_subscription_revenue, $self'strategy_address, $self'dev_address, $self'dex_address, $self'tech_incentive_address, $self'p2p_brokerage_address));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}


() __tact_selector_hack_asm() impure asm """
@atend @ 1 {
        execute current@ context@ current!
        {
            // The core idea of this function is to save gas by avoiding unnecessary dict jump, when recv_internal/recv_external is called
            // We want to extract recv_internal/recv_external from the dict and select needed function
            // not by jumping to the needed function by it's index, but by using usual IF statements.

            }END> b> // Close previous builder, now we have a cell of previous code on top of the stack

            <{ // Start of the new code builder
                SETCP0
                // Swap the new code builder with the previous code, now we have previous code on top of the stack
                swap
                // Transform cell to slice and load first ref from the previous code, now we have the dict on top of the stack
                <s ref@

                // Extract the recv_internal from the dict
                dup 0 swap @procdictkeylen idict@ { "internal shortcut error" abort } ifnot
                swap

                // Delete the recv_internal from the dict
                0 swap @procdictkeylen idict- drop
                // Delete the recv_external from the dict (it's okay if it's not there)
                -1 swap @procdictkeylen idict- drop
                // Delete the __tact_selector_hack from the dict
                65535 swap @procdictkeylen idict- drop

                // Bring the code builder from the bottom of the stack
                // because if recv_external extraction is optional, and the number of elements on the stack is not fixed
                depth 1- roll
                // Swap with the dict from which we extracted recv_internal and (maybe) recv_external
                swap

                // Check if the dict is empty
                dup null?
                // Store a copy of this flag in the bottom of the stack
                dup depth 1- -roll
                {
                    // If the dict is empty, just drop it (it will be null if it's empty)
                    drop
                }
                {
                    // If the dict is not empty, prepare continuation to be stored in c3
                    <{
                        // Save this dict as first ref in this continuation, it will be pushed in runtime by DICTPUSHCONST
                        swap @procdictkeylen DICTPUSHCONST
                        // Jump to the needed function by it's index
                        DICTIGETJMPZ
                        // If such key is not found, throw 11 along with the key as an argument
                        11 THROWARG
                    }> PUSHCONT
                    // Store the continuation in c3
                    c3 POP
                } cond

                // Function id is on top of the (runtime) stack
                DUP IFNOTJMP:<{
                    // place recv_internal here
                    DROP swap @addop
                }>

                // Bring back the flag, indicating if the dict is empty or not from the bottom of the stack
                depth 1- roll
                {
                    // If the dict is empty, throw 11
                    11 THROWARG
                }
                {
                    // If the dict is not empty, jump to continuation from c3
                    c3 PUSH JMPX
                } cond
            }> b>
        } : }END>c
        current@ context! current!
    } does @atend !
""";

() __tact_selector_hack() method_id(65535) {
    return __tact_selector_hack_asm();
}