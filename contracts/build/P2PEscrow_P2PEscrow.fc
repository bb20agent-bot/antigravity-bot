(slice, int) $P2PEscrow$_contract_load() impure inline {
    slice $sc = get_data().begin_parse();
    int $loaded = $sc~load_int(1);
    if ($loaded) {
        return $sc~$P2PEscrow$_load();
    }
    else {
        (slice $owner) = $sc~$P2PEscrow$init$_load();
        $sc.end_parse();
        return $P2PEscrow$_contract_init($owner);
    }
}

() $P2PEscrow$_contract_store((slice, int) v) impure inline {
    builder b = begin_cell();
    b = b.store_int(true, 1);
    b = $P2PEscrow$_store(b, v);
    set_data(b.end_cell());
}

