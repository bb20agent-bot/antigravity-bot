(slice, int) $P2PEscrow$_contract_init(slice $owner) impure inline {
    var (($self'owner, $self'orderCounter)) = (null(), null());
    $self'owner = $owner;
    $self'orderCounter = 0;
    return ($self'owner, $self'orderCounter);
}

