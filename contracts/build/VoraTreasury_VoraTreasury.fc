    ($self'allocations'dex, $self'allocations'tap, $self'allocations'team, $self'allocations'ido) = $Allocation$_constructor_dex_tap_team_ido(400000000000000000, 300000000000000000, 200000000000000000, 100000000000000000);
    return ($self'owner, ($self'allocations'dex, $self'allocations'tap, $self'allocations'team, $self'allocations'ido), $self'jettonWallet);
}

